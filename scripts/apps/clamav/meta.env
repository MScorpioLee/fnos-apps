FILE_PREFIX=clamav
RELEASE_TITLE="ClamAV"
DEFAULT_PORT=3310
HOMEPAGE_URL="https://github.com/Cisco-Talos/clamav"
CATEGORY=system
# Upstream clamav/clamav image only ships amd64 manifest — ARM builds fail at
# docker pull with 'no matching manifest for linux/arm64/v8' (issue #107).
# Restrict to x86 until upstream adds ARM manifests or a maintained multi-arch
# fork emerges.
SUPPORTED_ARCH="x86"
