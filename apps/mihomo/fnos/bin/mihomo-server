#!/bin/bash
# fnOS launcher: just exec fnos-mihomo-dashboard. Dashboard supervises
# mihomo as a subprocess (start / stop / restart from the UI). It also
# writes a starter config.yaml on first run.
APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR=$1

CONF_DIR="$APP_DATA_DIR/config"
CONFIG_FILE="$CONF_DIR/config.yaml"
LOG_FILE="$APP_DATA_DIR/mihomo.log"
UI_DIR="$APP_DIR/metacubexd"

mkdir -p "$CONF_DIR"

exec "$APP_DIR/fnos-mihomo-dashboard" \
    -listen ":${TRIM_SERVICE_PORT}" \
    -mihomo-api "http://127.0.0.1:19090" \
    -mihomo-bin "$APP_DIR/mihomo" \
    -mihomo-config-dir "$CONF_DIR" \
    -config "$CONFIG_FILE" \
    -log "$LOG_FILE" \
    -metacubexd "$UI_DIR"
