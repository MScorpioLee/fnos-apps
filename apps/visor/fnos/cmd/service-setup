#!/bin/bash

COMPOSE_FILE="${TRIM_APPDEST}/docker/docker-compose.yaml"
PORT_SAVE="${TRIM_PKGVAR}/.port"
API_HOST_SAVE="${TRIM_PKGVAR}/.api_host"
CREDENTIALS_FILE="${TRIM_PKGVAR}/CREDENTIALS.txt"

# 生成 URL-safe 随机字符串
gen_secret() {
    local len="${1:-16}"
    if command -v openssl >/dev/null 2>&1; then
        openssl rand -hex "$len" | head -c "$((len * 2))"
    else
        head -c "$((len * 2))" /dev/urandom | base64 | tr -dc 'a-zA-Z0-9' | head -c "$((len * 2))"
    fi
}

# Visor service env values: 写入 docker-compose.yaml 的 environment: 段, 通过 sed
# 替换占位符。fnOS 通过 Docker API 直接读 compose, 不支持 env_file 也不会
# 解析 ${VAR} (参考 8de46d1 fix(7 apps))。
patch_compose_secret() {
    local placeholder="$1"
    local value="$2"
    local escaped="${value//|/\\|}"
    sed -i "s|${placeholder}|${escaped}|g" "$COMPOSE_FILE"
}

apply_port() {
    local port="$1"
    [ -z "$port" ] && return
    sed -i 's/"[^"]*:80"/"'"${port}"':80"/' "$COMPOSE_FILE"
    echo "${port}" > "$PORT_SAVE"
    install_log "Patched docker-compose.yaml: port=${port}"
}

apply_api_host() {
    local host="$1"
    [ -z "$host" ] && host="0.0.0.0"
    patch_compose_secret "__API_HOST__" "$host"
    echo "${host}" > "$API_HOST_SAVE"
    install_log "Patched docker-compose.yaml: API_HOST=${host}"
}

service_postinst() {
    for sub in service/root-orion mysql/var-lib-mysql mysql/var-lib-mysql-files \
               redis/data influxdb/data influxdb/config \
               guacd/drive guacd/var-logs guacd/local-guacamole-lib guacd/local-guacamole-extensions; do
        mkdir -p "${TRIM_PKGVAR}/volumes/$sub" 2>/dev/null || true
    done

    local mysql_pw mysql_root_pw redis_pw influxdb_token influxdb_admin_pw secret_key api_expose_token
    if [ -f "$CREDENTIALS_FILE" ]; then
        mysql_pw=$(grep '^MYSQL_PASSWORD=' "$CREDENTIALS_FILE" | cut -d= -f2-)
        mysql_root_pw=$(grep '^MYSQL_ROOT_PASSWORD=' "$CREDENTIALS_FILE" | cut -d= -f2-)
        redis_pw=$(grep '^REDIS_PASSWORD=' "$CREDENTIALS_FILE" | cut -d= -f2-)
        influxdb_token=$(grep '^INFLUXDB_TOKEN=' "$CREDENTIALS_FILE" | cut -d= -f2-)
        influxdb_admin_pw=$(grep '^INFLUXDB_ADMIN_PASSWORD=' "$CREDENTIALS_FILE" | cut -d= -f2-)
        secret_key=$(grep '^SECRET_KEY=' "$CREDENTIALS_FILE" | cut -d= -f2-)
        api_expose_token=$(grep '^API_EXPOSE_TOKEN=' "$CREDENTIALS_FILE" | cut -d= -f2-)
        install_log "Reusing existing credentials from $CREDENTIALS_FILE"
    else
        mysql_pw=$(gen_secret 16)
        mysql_root_pw=$(gen_secret 16)
        redis_pw=$(gen_secret 16)
        influxdb_token=$(gen_secret 16)
        influxdb_admin_pw=$(gen_secret 16)
        secret_key=$(gen_secret 16)
        api_expose_token=$(gen_secret 16)

        umask 077
        cat > "$CREDENTIALS_FILE" <<CREDS
# Orion Visor 自动生成的内部服务凭证。请勿编辑或删除 — 升级/重装时会复用。
# 这些是数据库/缓存/监控服务的内部认证 token, 用户感知不到。
# 真正的登录账号在 Web UI: 首次默认 admin/admin, 登录后请立即修改。
MYSQL_PASSWORD=${mysql_pw}
MYSQL_ROOT_PASSWORD=${mysql_root_pw}
REDIS_PASSWORD=${redis_pw}
INFLUXDB_TOKEN=${influxdb_token}
INFLUXDB_ADMIN_PASSWORD=${influxdb_admin_pw}
SECRET_KEY=${secret_key}
API_EXPOSE_TOKEN=${api_expose_token}
CREDS
        install_log "Generated new credentials → $CREDENTIALS_FILE"
    fi

    patch_compose_secret "__MYSQL_PASSWORD__" "$mysql_pw"
    patch_compose_secret "__MYSQL_ROOT_PASSWORD__" "$mysql_root_pw"
    patch_compose_secret "__REDIS_PASSWORD__" "$redis_pw"
    patch_compose_secret "__INFLUXDB_TOKEN__" "$influxdb_token"
    patch_compose_secret "__INFLUXDB_ADMIN_PASSWORD__" "$influxdb_admin_pw"
    patch_compose_secret "__SECRET_KEY__" "$secret_key"
    patch_compose_secret "__API_EXPOSE_TOKEN__" "$api_expose_token"

    apply_api_host "${wizard_api_host:-0.0.0.0}"
}

service_postupgrade() {
    service_postinst
    [ -f "$PORT_SAVE" ] && apply_port "$(cat "$PORT_SAVE")"
    [ -f "$API_HOST_SAVE" ] && apply_api_host "$(cat "$API_HOST_SAVE")"
}

service_postconfig() {
    [ -n "${wizard_port:-}" ] && apply_port "${wizard_port}"
    [ -n "${wizard_api_host:-}" ] && apply_api_host "${wizard_api_host}"
}
